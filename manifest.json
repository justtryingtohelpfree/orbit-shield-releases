{
  "manifest_version": 2,
  "name": "Orbit Shield — Universal Ad Blocker",
  "version": "3.0.0",
  "description": "Aggressive network-level ad/tracker blocking, YouTube ad speed-kill, and universal cookie banner removal.",

  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "storage",
    "<all_urls>"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },

  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["sniper.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "orbit-shield-remote@orbit.browser",
      "strict_min_version": "113.0"
    }
  }
}
